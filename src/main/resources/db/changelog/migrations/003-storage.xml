<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
     xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="
     http://www.liquibase.org/xml/ns/dbchangelog
     https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

<changeSet id="010-storage-schema" author="abubakar">

    <sql>
        CREATE SCHEMA IF NOT EXISTS storage;
    </sql>

</changeSet>

<changeSet id="011-storage-files" author="abubakar">

    <createTable
            schemaName="storage"
            tableName="files">

        <column name="id" type="BIGSERIAL">
            <constraints primaryKey="true"/>
        </column>

        <column
                name="file_name"
                type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column
                name="original_file_name"
                type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column
                name="content_type"
                type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column
                name="size_bytes"
                type="BIGINT">
            <constraints nullable="false"/>
        </column>

        <column
                name="provider"
                type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>

        <column
            name="status"
            type="VARCHAR(50)"
            defaultValue="PENDING">

        <constraints nullable="false"/>
        </column>

        <column
                name="storage_key"
                type="VARCHAR(1000)">
            <constraints nullable="false"/>
        </column>

        <column
                name="uploaded_by"
                type="BIGINT"/>

        <column
                name="created_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column
                name="deleted_at"
                type="TIMESTAMP"/>

    </createTable>

    <addForeignKeyConstraint
            baseTableSchemaName="storage"
            baseTableName="files"
            baseColumnNames="uploaded_by"
            referencedTableSchemaName="auth"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_files_uploaded_by"/>

    <createIndex
            schemaName="storage"
            tableName="files"
            indexName="idx_files_uploaded_by">

        <column name="uploaded_by"/>

    </createIndex>

    <createIndex
            schemaName="storage"
            tableName="files"
            indexName="idx_files_created_at">

        <column name="created_at"/>

    </createIndex>

    <createIndex
            schemaName="storage"
            tableName="files"
            indexName="idx_files_deleted_at">

        <column name="deleted_at"/>

    </createIndex>

    <createIndex
        schemaName="storage"
        tableName="files"
        indexName="idx_files_status">

    <column name="status"/>

</createIndex>

</changeSet>

</databaseChangeLog>
