<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
     xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="
         http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

<changeSet id="001-create-auth-schema" author="abubakar">
    <sql>
        CREATE SCHEMA IF NOT EXISTS auth;
    </sql>
</changeSet>

<changeSet id="002-create-roles" author="abubakar">

    <createTable schemaName="auth" tableName="roles">

        <column name="id" type="BIGINT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="code" type="VARCHAR(50)">
            <constraints nullable="false" unique="true"/>
        </column>

        <column name="name" type="VARCHAR(100)">
            <constraints nullable="false"/>
        </column>

        <column name="created_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

        <column name="updated_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

    </createTable>

</changeSet>

<changeSet id="003-create-users" author="abubakar">

    <createTable schemaName="auth" tableName="users">

        <column name="id" type="BIGINT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="username" type="VARCHAR(100)">
            <constraints nullable="false" unique="true"/>
        </column>

        <column name="email" type="VARCHAR(320)">
            <constraints nullable="false" unique="true"/>
        </column>

        <column name="password_hash" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="enabled"
                type="BOOLEAN"
                defaultValueBoolean="true">
            <constraints nullable="false"/>
        </column>

        <column name="role_id" type="BIGINT">
            <constraints nullable="false"/>
        </column>

        <column name="last_sign_in_at"
                type="TIMESTAMP"/>

        <column name="created_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

        <column name="updated_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

        <column name="deleted_at"
                type="TIMESTAMP"/>

    </createTable>

    <addForeignKeyConstraint
            baseTableSchemaName="auth"
            baseTableName="users"
            baseColumnNames="role_id"
            referencedTableSchemaName="auth"
            referencedTableName="roles"
            referencedColumnNames="id"
            constraintName="fk_users_role"/>

    <createIndex
            schemaName="auth"
            tableName="users"
            indexName="idx_users_role_id">

        <column name="role_id"/>

    </createIndex>

    <createIndex
            schemaName="auth"
            tableName="users"
            indexName="idx_users_deleted_at">

        <column name="deleted_at"/>

    </createIndex>

    <createIndex
            schemaName="auth"
            tableName="users"
            indexName="idx_users_enabled">

        <column name="enabled"/>

    </createIndex>

</changeSet>

<changeSet id="004-create-sessions" author="abubakar">

    <createTable schemaName="auth" tableName="sessions">

        <column name="id" type="BIGINT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="user_id" type="BIGINT">
            <constraints nullable="false"/>
        </column>

        <column name="user_agent" type="VARCHAR(500)"/>

        <column name="ip_address" type="VARCHAR(100)"/>

        <column name="revoked"
                type="BOOLEAN"
                defaultValueBoolean="false">
            <constraints nullable="false"/>
        </column>

        <column name="created_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

        <column name="last_accessed_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

    </createTable>

    <addForeignKeyConstraint
            baseTableSchemaName="auth"
            baseTableName="sessions"
            baseColumnNames="user_id"
            referencedTableSchemaName="auth"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_sessions_user"/>

    <createIndex
            schemaName="auth"
            tableName="sessions"
            indexName="idx_sessions_user_id">

        <column name="user_id"/>

    </createIndex>

</changeSet>

<changeSet id="005-create-refresh-tokens" author="abubakar">

    <createTable schemaName="auth" tableName="refresh_tokens">

        <column name="id" type="BIGINT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="user_id" type="BIGINT">
            <constraints nullable="false"/>
        </column>

        <column name="session_id" type="BIGINT">
            <constraints nullable="false"/>
        </column>

        <column name="token" type="UUID">
            <constraints nullable="false" unique="true"/>
        </column>

        <column name="expires_at" type="TIMESTAMP">
            <constraints nullable="false"/>
        </column>

        <column name="revoked"
                type="BOOLEAN"
                defaultValueBoolean="false">
            <constraints nullable="false"/>
        </column>

        <column name="created_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

        <column name="updated_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

    </createTable>

    <addForeignKeyConstraint
            baseTableSchemaName="auth"
            baseTableName="refresh_tokens"
            baseColumnNames="user_id"
            referencedTableSchemaName="auth"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_refresh_tokens_user"/>

    <addForeignKeyConstraint
            baseTableSchemaName="auth"
            baseTableName="refresh_tokens"
            baseColumnNames="session_id"
            referencedTableSchemaName="auth"
            referencedTableName="sessions"
            referencedColumnNames="id"
            constraintName="fk_refresh_tokens_session"/>

</changeSet>
<changeSet id="006-create-identities" author="abubakar">

    <createTable schemaName="auth" tableName="identities">

        <column name="id" type="BIGINT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="user_id" type="BIGINT">
            <constraints nullable="false"/>
        </column>

        <column name="provider" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>

        <column name="provider_user_id" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="created_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

    </createTable>

    <addForeignKeyConstraint
            baseTableSchemaName="auth"
            baseTableName="identities"
            baseColumnNames="user_id"
            referencedTableSchemaName="auth"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_identities_user"/>

    <createIndex
            schemaName="auth"
            tableName="identities"
            indexName="idx_identities_user_id">

        <column name="user_id"/>

    </createIndex>

    <addUniqueConstraint
            schemaName="auth"
            tableName="identities"
            columnNames="provider,provider_user_id"
            constraintName="uk_identity_provider"/>

</changeSet>

<changeSet id="007-create-password-reset-tokens" author="abubakar">

    <createTable schemaName="auth"
                 tableName="password_reset_tokens">

        <column name="id"
                type="BIGINT"
                autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="user_id" type="BIGINT">
            <constraints nullable="false"/>
        </column>

        <column name="token" type="UUID">
            <constraints nullable="false"
                         unique="true"/>
        </column>

        <column name="expires_at" type="TIMESTAMP">
            <constraints nullable="false"/>
        </column>

        <column name="used"
                type="BOOLEAN"
                defaultValueBoolean="false">
            <constraints nullable="false"/>
        </column>

        <column name="created_at"
                type="TIMESTAMP"
                defaultValueComputed="CURRENT_TIMESTAMP">
            <constraints nullable="false"/>
        </column>

    </createTable>

    <addForeignKeyConstraint
            baseTableSchemaName="auth"
            baseTableName="password_reset_tokens"
            baseColumnNames="user_id"
            referencedTableSchemaName="auth"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_password_reset_user"/>

    <createIndex
            schemaName="auth"
            tableName="password_reset_tokens"
            indexName="idx_password_reset_user_id">

        <column name="user_id"/>

    </createIndex>

    <createIndex
            schemaName="auth"
            tableName="password_reset_tokens"
            indexName="idx_password_reset_expires">

        <column name="expires_at"/>

    </createIndex>

</changeSet>

</databaseChangeLog>
